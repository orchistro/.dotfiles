    "yellow": "#dfa000",
    "green": "#8da101",
    "aqua": "#35a77c",
    "blue": "#3a94c5",
    "purple": "#df69ba"
  },
  "theme": {
    "primary": {
      "dark": "green",
      "light": "green"
    },
    "secondary": {
      "dark": "aqua",
      "light": "aqua"
