{
  "$schema": "https://opencode.ai/theme.json",
  "defs": {
    "bg": "#fdf6e3",
    "bg-dim": "#f4f0d9",
    "bg1": "#efebd4",
    "bg2": "#e9e5cf",
    "bg3": "#e1ddc9",
    "bg4": "#ddd8be",
    "bg5": "#d8d3ba",
    "fg": "#5c6a72",
    "grey0": "#a6b0a0",
    "grey1": "#939f91",
    "grey2": "#829181",
    "red": "#f85552",
